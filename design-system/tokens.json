{
  "$description": "Parvez Kose — Design System tokens (W3C DTCG format). Canonical source for parvezkose.com. Mirrored to app/global.css via Tailwind v4 @theme. Re-emit for Figma variables / Style Dictionary downstream.",
  "$metadata": {
    "name": "parvezkose.com",
    "version": "1.0.0",
    "license": "All rights reserved",
    "homepage": "https://parvezkose.com",
    "specimens": "https://parvezkose.com/design-system/",
    "source": "claude-design/Parvez Kose Site Design System 04-22/colors_and_type.css"
  },

  "color": {
    "$description": "Three families (wines, accents, wood, neutrals) plus mode surfaces. The red spine + warm earth tones replace Linear-genre purple/indigo and cool-gray.",

    "wine": {
      "$description": "The red spine of the brand. Drawn from the volcanic shader's valleys and peaks.",
      "crimson":   { "$value": "#dc143c", "$type": "color" },
      "raspberry": { "$value": "#e30b5c", "$type": "color" },
      "garnet":    { "$value": "#b21e35", "$type": "color" },
      "ruby":      { "$value": "#9b111e", "$type": "color" },
      "wine":      { "$value": "#722f37", "$type": "color", "$description": "Signature mid-wine." },
      "burgundy":  { "$value": "#800020", "$type": "color" },
      "claret":    { "$value": "#6f2232", "$type": "color" },
      "cabernet":  { "$value": "#5e1224", "$type": "color" },
      "merlot":    { "$value": "#7b3f52", "$type": "color" },
      "shiraz":    { "$value": "#673147", "$type": "color" },
      "oxblood":   { "$value": "#4e0707", "$type": "color" },
      "sangria":   { "$value": "#4c0027", "$type": "color" },
      "port":      { "$value": "#3c0014", "$type": "color" },
      "noir":      { "$value": "#2c0010", "$type": "color" },
      "abyss":     { "$value": "#1a0005", "$type": "color" }
    },

    "accent": {
      "$description": "Warm earth accents. Used sparingly: terracotta = interaction, golden = once per screen.",
      "terracotta": { "$value": "#e2725b", "$type": "color", "$description": "PRIMARY accent. Hover rules, CTA borders, active states." },
      "rust":       { "$value": "#b7410e", "$type": "color" },
      "cognac":     { "$value": "#9f381d", "$type": "color" },
      "chili":      { "$value": "#c04000", "$type": "color" },
      "golden":     { "$value": "#c4a000", "$type": "color", "$description": "Reserved — one badge or one underline per screen." },
      "mulberry":   { "$value": "#c54b6c", "$type": "color" }
    },

    "wood": {
      "$description": "Browns / wood tones. Borders, dividers, editorial accents.",
      "mahogany": { "$value": "#4c3024", "$type": "color" },
      "walnut":   { "$value": "#5c4033", "$type": "color" },
      "coffee":   { "$value": "#6f4e37", "$type": "color" },
      "grizzly":  { "$value": "#685542", "$type": "color" }
    },

    "neutral": {
      "$description": "Ivory/linen terrain. Warm, paper-like — replaces cool gray.",
      "ivory":     { "$value": "#fffff0", "$type": "color" },
      "cream":     { "$value": "#fffdd0", "$type": "color" },
      "linen":     { "$value": "#faf0e6", "$type": "color" },
      "beige":     { "$value": "#f5f5dc", "$type": "color" },
      "champagne": { "$value": "#f7e7ce", "$type": "color" },
      "bisque":    { "$value": "#ffe4c4", "$type": "color" },
      "almond":    { "$value": "#efdecd", "$type": "color" },
      "khaki":     { "$value": "#c3b091", "$type": "color" },
      "latte":     { "$value": "#c8ad8f", "$type": "color", "$description": "Secondary muted on dark. Replaces cold gray for metadata." },
      "black":     { "$value": "#000000", "$type": "color" }
    },

    "surface": {
      "$description": "Mode-specific surface palettes. Two collections in Figma: 'immersive' and 'classic'.",
      "immersive": {
        "$description": "Dark, volcanic. Used on / (main landing) over WebGL shader.",
        "bg":      { "$value": "#0a0a0a", "$type": "color", "$description": "Page base behind shader." },
        "bg2":     { "$value": "#141414", "$type": "color", "$description": "Elevated surfaces, cards." },
        "bg3":     { "$value": "#1a1a1a", "$type": "color", "$description": "Hover on bg2, inputs." },
        "text":    { "$value": "#e8e4e0", "$type": "color", "$description": "Warm white, NOT pure white." },
        "text2":   { "$value": "#9a9590", "$type": "color", "$description": "Muted — bio, metadata." },
        "text3":   { "$value": "#5a5550", "$type": "color", "$description": "Tertiary — footer, disabled." },
        "border":  { "$value": "#2a2520", "$type": "color", "$description": "Warm-tinted hairline." },
        "border2": { "$value": "rgba(200, 173, 143, 0.15)", "$type": "color", "$description": "Latte @ 15% — cards on shader." }
      },
      "classic": {
        "$description": "Light, bone-paper. Used on /classic — graphite ink, mono.",
        "bg":     { "$value": "#f1f2f2", "$type": "color" },
        "fg":     { "$value": "#1a1a1a", "$type": "color" },
        "fg2":    { "$value": "#555555", "$type": "color" },
        "fg3":    { "$value": "#999999", "$type": "color" },
        "border": { "$value": "#d8d9d9", "$type": "color" }
      }
    },

    "overlay": {
      "$description": "White-on-shader overlay opacities (immersive hero copy).",
      "hi": { "$value": "rgba(255, 255, 255, 0.95)", "$type": "color" },
      "md": { "$value": "rgba(255, 255, 255, 0.88)", "$type": "color" },
      "lo": { "$value": "rgba(255, 255, 255, 0.55)", "$type": "color" }
    }
  },

  "font": {
    "family": {
      "sans":  { "$value": ["IBM Plex Sans", "ui-sans-serif", "system-ui", "sans-serif"], "$type": "fontFamily", "$description": "Prose, UI body, forms, buttons." },
      "serif": { "$value": ["IBM Plex Serif", "ui-serif", "Georgia", "serif"], "$type": "fontFamily", "$description": "Blog H1 only — one weight, once per article." },
      "mono":  { "$value": ["JetBrains Mono", "Fira Code", "ui-monospace", "SF Mono", "Menlo", "monospace"], "$type": "fontFamily", "$description": "Headings on immersive; entire /classic surface; metadata, eyebrows, nav." },
      "code":  { "$value": ["Fira Code", "JetBrains Mono", "ui-monospace", "monospace"], "$type": "fontFamily", "$description": "Immersive subtitle and footer tagline (ligature-rich)." }
    },

    "weight": {
      "$description": "Restrained. Never default to 700.",
      "light":     { "$value": 300, "$type": "fontWeight", "$description": "Display." },
      "regular":   { "$value": 400, "$type": "fontWeight", "$description": "Body." },
      "medium":    { "$value": 500, "$type": "fontWeight", "$description": "Eyebrows, nav, headings." },
      "semibold":  { "$value": 600, "$type": "fontWeight", "$description": "Rare emphasis only." }
    },

    "size": {
      "$description": "Numeric scale at 16px base. Matches DS --text-* names.",
      "10": { "$value": "0.625rem",  "$type": "dimension", "$description": "Micro labels, eyebrows." },
      "11": { "$value": "0.6875rem", "$type": "dimension", "$description": "Footer, small-caps nav." },
      "12": { "$value": "0.75rem",   "$type": "dimension", "$description": "Bio / body on classic card." },
      "13": { "$value": "0.8125rem", "$type": "dimension", "$description": "Links." },
      "14": { "$value": "0.875rem",  "$type": "dimension", "$description": "Prose base." },
      "16": { "$value": "1rem",      "$type": "dimension", "$description": "Base." },
      "18": { "$value": "1.125rem",  "$type": "dimension", "$description": "Intro." },
      "20": { "$value": "1.25rem",   "$type": "dimension", "$description": "H4." },
      "24": { "$value": "1.5rem",    "$type": "dimension", "$description": "H3." },
      "28": { "$value": "1.75rem",   "$type": "dimension", "$description": "Classic card hero name." },
      "36": { "$value": "2.25rem",   "$type": "dimension", "$description": "H2 / blog title." },
      "48": { "$value": "3rem",      "$type": "dimension", "$description": "Immersive hero (sm)." },
      "60": { "$value": "3.75rem",   "$type": "dimension", "$description": "Immersive hero (md)." },
      "72": { "$value": "4.5rem",    "$type": "dimension", "$description": "Display." }
    },

    "tracking": {
      "$description": "Letter-spacing. Tight on display, widest on monospace caps.",
      "tight":      { "$value": "-0.02em", "$type": "dimension" },
      "snug":       { "$value": "-0.01em", "$type": "dimension" },
      "normal":     { "$value": "0",       "$type": "dimension" },
      "wide":       { "$value": "0.04em",  "$type": "dimension" },
      "wider":      { "$value": "0.08em",  "$type": "dimension" },
      "widest":     { "$value": "0.12em",  "$type": "dimension", "$description": "Eyebrows, nav links." },
      "mono-caps":  { "$value": "0.14em",  "$type": "dimension", "$description": "Immersive nav + footer tagline." }
    },

    "leading": {
      "tight": { "$value": 1.15, "$type": "number", "$description": "Display." },
      "snug":  { "$value": 1.3,  "$type": "number" },
      "base":  { "$value": 1.5,  "$type": "number", "$description": "UI." },
      "prose": { "$value": 1.7,  "$type": "number", "$description": "Prose." },
      "loose": { "$value": 1.8,  "$type": "number", "$description": "Bio." }
    }
  },

  "spacing": {
    "$description": "4px grid. Matches Tailwind v4 default spacing exactly (no override needed).",
    "1":  { "$value": "4px",  "$type": "dimension" },
    "2":  { "$value": "8px",  "$type": "dimension" },
    "3":  { "$value": "12px", "$type": "dimension" },
    "4":  { "$value": "16px", "$type": "dimension" },
    "5":  { "$value": "20px", "$type": "dimension" },
    "6":  { "$value": "24px", "$type": "dimension", "$description": "Card padding." },
    "7":  { "$value": "28px", "$type": "dimension" },
    "8":  { "$value": "32px", "$type": "dimension" },
    "10": { "$value": "40px", "$type": "dimension" },
    "12": { "$value": "48px", "$type": "dimension", "$description": "Topbar height." },
    "16": { "$value": "64px", "$type": "dimension" },
    "20": { "$value": "80px", "$type": "dimension", "$description": "Page top gutter on /classic." }
  },

  "radius": {
    "$description": "Understated. Avoid 2xl/3xl rounding. Immersive hero uses zero radius and corner brackets instead.",
    "sm":   { "$value": "4px",   "$type": "dimension" },
    "md":   { "$value": "6px",   "$type": "dimension" },
    "lg":   { "$value": "8px",   "$type": "dimension" },
    "xl":   { "$value": "12px",  "$type": "dimension" },
    "pill": { "$value": "999px", "$type": "dimension" }
  },

  "shadow": {
    "$description": "Quiet. Ink-on-paper, not floating cards. The two text-shadow stacks are LOAD-BEARING for AA contrast over the volcanic shader — do not soften.",
    "text-hero": {
      "$value": "0 1px 3px rgba(0,0,0,0.95), 0 0 28px rgba(0,0,0,0.65), 0 0 56px rgba(0,0,0,0.35)",
      "$type": "shadow",
      "$description": "Hero H1 over shader. Required for legibility, not polish."
    },
    "text-hero-hover": {
      "$value": "0 2px 6px rgba(0,0,0,1), 0 0 36px rgba(0,0,0,0.85), 0 0 72px rgba(0,0,0,0.5)",
      "$type": "shadow",
      "$description": "Press-into-terrain effect on hover."
    },
    "text-sub": {
      "$value": "0 1px 2px rgba(0,0,0,0.95), 0 0 18px rgba(0,0,0,0.8), 0 0 36px rgba(0,0,0,0.45)",
      "$type": "shadow",
      "$description": "Subtitle / secondary copy over shader."
    },
    "card-dark":  { "$value": "0 8px 32px rgba(0,0,0,0.45)", "$type": "shadow" },
    "card-light": { "$value": "0 1px 2px rgba(0,0,0,0.04)",  "$type": "shadow" }
  },

  "gradient": {
    "protect": {
      "$value": "linear-gradient(90deg, rgba(0,0,0,0.78) 0%, rgba(0,0,0,0.42) 52%, rgba(0,0,0,0) 100%)",
      "$type": "gradient",
      "$description": "Sits under floating labels on the shader. Left-to-transparent so labels read without a solid pill."
    }
  },

  "motion": {
    "duration": {
      "fast": { "$value": "150ms", "$type": "duration", "$description": "Hover color." },
      "base": { "$value": "300ms", "$type": "duration", "$description": "Letter-spacing on nav, drawer toggles." },
      "slow": { "$value": "500ms", "$type": "duration", "$description": "Philosophy panel expand." }
    },
    "easing": {
      "out-quad":  { "$value": "cubic-bezier(0.33, 1, 0.68, 1)",     "$type": "cubicBezier", "$description": "Default." },
      "out-cubic": { "$value": "cubic-bezier(0.215, 0.61, 0.355, 1)", "$type": "cubicBezier" }
    }
  },

  "layout": {
    "card-max":  { "$value": "640px", "$type": "dimension", "$description": "/classic single-column card." },
    "prose-max": { "$value": "640px", "$type": "dimension", "$description": "Blog post column." }
  }
}
